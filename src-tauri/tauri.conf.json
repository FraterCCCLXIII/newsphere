{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Newsphere",
  "version": "0.1.0",
  "identifier": "com.newsphere.app",
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Newsphere",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "transparent": true
      }
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
